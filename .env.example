# Copy to `.env.local` for local development (never commit `.env.local`).
#
# 1) Generate a matching RSA keypair:
#    node scripts/generate-apply-keys.mjs
# 2) Paste the two printed lines (NEXT_PUBLIC_… and APPLY_RSA_…) below, OR paste
#    the script output directly into `.env.local`.

# Client + server: public PEM (build-time; safe to expose)
NEXT_PUBLIC_APPLY_RSA_PUBLIC_KEY_PEM=

# Server only: private PEM — never commit real values; use Vercel/host secrets in production
APPLY_RSA_PRIVATE_KEY_PEM=

# Email (apply + contact)
# RESEND_API_KEY=
# RESEND_FROM=
# APPLY_EMAIL=
# CONTACT_EMAIL=
